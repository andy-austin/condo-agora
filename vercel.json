{
  "routes": [
    {
      "src": "/api/auth/otp/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "apps/web/api/auth/$1"
    },
    {
      "src": "/api/(?!upload)(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web/$1"
    }
  ]
}
